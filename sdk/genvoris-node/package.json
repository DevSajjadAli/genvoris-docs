{
  "name": "@genvoris/node",
  "version": "1.0.1",
  "description": "Official Node.js SDK for the Genvoris Virtual Try-On API",
  "license": "MIT",
  "author": "Genvoris <support@genvoris.org>",
  "homepage": "https://docs.genvoris.org/api/sdk-node",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevSajjadAli/genvoris-docs.git",
    "directory": "sdk/genvoris-node"
  },
  "bugs": {
    "email": "support@genvoris.org",
    "url": "https://github.com/DevSajjadAli/genvoris-docs/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "pretest": "npm run build",
    "test": "node --test \"test/*.test.mjs\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "genvoris",
    "virtual-try-on",
    "vton",
    "ecommerce",
    "ai",
    "fashion",
    "shopify",
    "woocommerce",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": ">=18",
    "typescript": "^5.4.5",
    "tsup": "^8.0.2"
  }
}
